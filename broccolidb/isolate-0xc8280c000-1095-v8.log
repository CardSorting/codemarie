script-source,76,node:internal/v8_prof_processor,'use strict';\n\nconst {\n  ArrayPrototypePush\x2C\n  ArrayPrototypePushApply\x2C\n  ArrayPrototypeSlice\x2C\n  StringPrototypeSlice\x2C\n} = primordials;\n\nconst Buffer = require('buffer').Buffer;\nconst console = require('internal/console/global');\nconst vm = require('vm');\nconst { SourceTextModule } = require('internal/vm/module');\n\nconst { natives } = internalBinding('builtins');\n\nasync function linker(specifier\x2C referencingModule) {\n  // Transform "./file.mjs" to "file"\n  const file = StringPrototypeSlice(specifier\x2C 2\x2C -4);\n  const code = natives[`internal/deps/v8/tools/${file}`];\n  return new SourceTextModule(code\x2C { context: referencingModule.context });\n}\n\n(async () => {\n  const tickArguments = [];\n  if (process.platform === 'darwin') {\n    ArrayPrototypePush(tickArguments\x2C '--mac');\n  } else if (process.platform === 'win32') {\n    ArrayPrototypePush(tickArguments\x2C '--windows');\n  }\n  ArrayPrototypePushApply(tickArguments\x2C\n                          ArrayPrototypeSlice(process.argv\x2C 1));\n\n  const context = vm.createContext({\n    arguments: tickArguments\x2C\n    write(s) { process.stdout.write(s); }\x2C\n    printErr(err) { console.error(err); }\x2C\n    console\x2C\n    process\x2C\n    Buffer\x2C\n  });\n\n  const polyfill = natives['internal/v8_prof_polyfill'];\n  const script = `(function(module\x2C require) {\n    ${polyfill}\n  })`;\n\n  vm.runInContext(script\x2C context)(module\x2C require);\n\n  const tickProcessor = natives['internal/deps/v8/tools/tickprocessor-driver'];\n  const tickprocessorDriver = new SourceTextModule(tickProcessor\x2C { context });\n  await tickprocessorDriver.link(linker);\n  await tickprocessorDriver.evaluate();\n})();\n
