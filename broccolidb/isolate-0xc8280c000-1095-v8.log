script-source,112,vm:module(1),// Copyright 2012 the V8 project authors. All rights reserved.\n// Redistribution and use in source and binary forms\x2C with or without\n// modification\x2C are permitted provided that the following conditions are\n// met:\n//\n//     * Redistributions of source code must retain the above copyright\n//       notice\x2C this list of conditions and the following disclaimer.\n//     * Redistributions in binary form must reproduce the above\n//       copyright notice\x2C this list of conditions and the following\n//       disclaimer in the documentation and/or other materials provided\n//       with the distribution.\n//     * Neither the name of Google Inc. nor the names of its\n//       contributors may be used to endorse or promote products derived\n//       from this software without specific prior written permission.\n//\n// THIS SOFTWARE IS PROVIDED BY THE COPYRIGHT HOLDERS AND CONTRIBUTORS\n// "AS IS" AND ANY EXPRESS OR IMPLIED WARRANTIES\x2C INCLUDING\x2C BUT NOT\n// LIMITED TO\x2C THE IMPLIED WARRANTIES OF MERCHANTABILITY AND FITNESS FOR\n// A PARTICULAR PURPOSE ARE DISCLAIMED. IN NO EVENT SHALL THE COPYRIGHT\n// OWNER OR CONTRIBUTORS BE LIABLE FOR ANY DIRECT\x2C INDIRECT\x2C INCIDENTAL\x2C\n// SPECIAL\x2C EXEMPLARY\x2C OR CONSEQUENTIAL DAMAGES (INCLUDING\x2C BUT NOT\n// LIMITED TO\x2C PROCUREMENT OF SUBSTITUTE GOODS OR SERVICES; LOSS OF USE\x2C\n// DATA\x2C OR PROFITS; OR BUSINESS INTERRUPTION) HOWEVER CAUSED AND ON ANY\n// THEORY OF LIABILITY\x2C WHETHER IN CONTRACT\x2C STRICT LIABILITY\x2C OR TORT\n// (INCLUDING NEGLIGENCE OR OTHERWISE) ARISING IN ANY WAY OUT OF THE USE\n// OF THIS SOFTWARE\x2C EVEN IF ADVISED OF THE POSSIBILITY OF SUCH DAMAGE.\n\nimport { LogReader\x2C parseString\x2C parseVarArgs } from "./logreader.mjs";\nimport { BaseArgumentsProcessor\x2C parseBool } from "./arguments.mjs";\nimport { Profile\x2C JsonProfile } from "./profile.mjs";\nimport { ViewBuilder } from "./profile_view.mjs";\nimport { WebInspector} from "./sourcemap.mjs";\n\n\nclass V8Profile extends Profile {\n  static IC_RE =\n      /^(LoadGlobalIC: )|(Handler: )|(?:CallIC|LoadIC|StoreIC)|(?:Builtin: (?:Keyed)?(?:Load|Store)IC_)/;\n  static BYTECODES_RE = /^(BytecodeHandler: )/;\n  static SPARKPLUG_HANDLERS_RE = /^(Builtin: .*Baseline.*)/;\n  static BUILTINS_RE = /^(Builtin: )/;\n  static STUBS_RE = /^(Stub: )/;\n\n  constructor(separateIc\x2C separateBytecodes\x2C separateBuiltins\x2C separateStubs\x2C\n        separateSparkplugHandlers\x2C useBigIntAddresses=false) {\n    super(useBigIntAddresses);\n    const regexps = [];\n    if (!separateIc) regexps.push(V8Profile.IC_RE);\n    if (!separateBytecodes) regexps.push(V8Profile.BYTECODES_RE);\n    if (!separateBuiltins) regexps.push(V8Profile.BUILTINS_RE);\n    if (!separateStubs) regexps.push(V8Profile.STUBS_RE);\n    if (regexps.length > 0) {\n      this.skipThisFunction = function(name) {\n        for (let i = 0; i < regexps.length; i++) {\n          if (regexps[i].test(name)) return true;\n        }\n        return false;\n      };\n    }\n  }\n}\n\nclass CppEntriesProvider {\n  constructor(useBigIntAddresses=false) {\n    this._isEnabled = true;\n    this.parseAddr = useBigIntAddresses ? BigInt : parseInt;\n    this.parseHexAddr = useBigIntAddresses ?\n        (str) => BigInt(parseInt(str\x2C 16)) :\n        (str) => parseInt(str\x2C 16);\n\n  }\n\n  inRange(funcInfo\x2C start\x2C end) {\n    return funcInfo.start >= start && funcInfo.end <= end;\n  }\n\n  async parseVmSymbols(libName\x2C libStart\x2C libEnd\x2C libASLRSlide\x2C processorFunc) {\n    if (!this._isEnabled) return;\n    await this.loadSymbols(libName);\n\n    let lastUnknownSize;\n    let lastAdded;\n\n    let addEntry = (funcInfo) => {\n      // Several functions can be mapped onto the same address. To avoid\n      // creating zero-sized entries\x2C skip such duplicates.\n      // Also double-check that function belongs to the library address space.\n\n      if (lastUnknownSize &&\n        lastUnknownSize.start < funcInfo.start) {\n        // Try to update lastUnknownSize based on new entries start position.\n        lastUnknownSize.end = funcInfo.start;\n        if ((!lastAdded ||\n            !this.inRange(lastUnknownSize\x2C lastAdded.start\x2C lastAdded.end)) &&\n            this.inRange(lastUnknownSize\x2C libStart\x2C libEnd)) {\n          processorFunc(\n              lastUnknownSize.name\x2C lastUnknownSize.start\x2C lastUnknownSize.end);\n          lastAdded = lastUnknownSize;\n        }\n      }\n      lastUnknownSize = undefined;\n\n      if (funcInfo.end) {\n        // Skip duplicates that have the same start address as the last added.\n        if ((!lastAdded || lastAdded.start != funcInfo.start) &&\n          this.inRange(funcInfo\x2C libStart\x2C libEnd)) {\n          processorFunc(funcInfo.name\x2C funcInfo.start\x2C funcInfo.end);\n          lastAdded = funcInfo;\n        }\n      } else {\n        // If a funcInfo doesn't have an end\x2C try to match it up with the next\n        // entry.\n        lastUnknownSize = funcInfo;\n      }\n    }\n\n    while (true) {\n      const funcInfo = this.parseNextLine();\n      if (funcInfo === null) continue;\n      if (funcInfo === false) break;\n      if (funcInfo.start < libStart &&\n        funcInfo.start < libEnd - libStart) {\n        funcInfo.start += libStart;\n      } else {\n        funcInfo.start += libASLRSlide;\n      }\n      if (funcInfo.size) {\n        funcInfo.end = funcInfo.start + funcInfo.size;\n      }\n      addEntry(funcInfo);\n    }\n    addEntry({ name: ''\x2C start: libEnd });\n  }\n\n  async loadSymbols(libName) {}\n\n  async loadSymbolsRemote(platform\x2C libName) {\n    this.parsePos = 0;\n    const url = new URL("http://localhost:8000/v8/loadVMSymbols");\n    url.searchParams.set('libName'\x2C libName);\n    url.searchParams.set('platform'\x2C platform);\n    this._setRemoteQueryParams(url.searchParams);\n    let response;\n    let json;\n    try {\n      response = await fetch(url\x2C { timeout: 20 });\n      if (response.status == 404) {\n        throw new Error(\n          `Local symbol server returned 404: ${await response.text()}`);\n      }\n      json = await response.json();\n      if (json.error) console.warn(json.error);\n    } catch (e) {\n      if (!response || response.status == 404) {\n        // Assume that the local symbol server is not reachable.\n        console.warn("Disabling remote symbol loading:"\x2C e);\n        this._isEnabled = false;\n        return;\n      }\n    }\n    this._handleRemoteSymbolsResult(json);\n  }\n\n  _setRemoteQueryParams(searchParams) {\n    // Subclass responsibility.\n  }\n\n  _handleRemoteSymbolsResult(json) {\n    this.symbols = json.symbols;\n  }\n\n  parseNextLine() { return false }\n}\n\nexport class LinuxCppEntriesProvider extends CppEntriesProvider {\n  constructor(\n        nmExec\x2C objdumpExec\x2C readelfExec\x2C targetRootFS\x2C apkEmbeddedLibrary\x2C\n        useBigIntAddresses=false) {\n    super(useBigIntAddresses);\n    this.symbols = [];\n    // File offset of a symbol minus the virtual address of a symbol found in\n    // the symbol table.\n    this.fileOffsetMinusVma = useBigIntAddresses ? 0n : 0;\n    this.parsePos = 0;\n    this.nmExec = nmExec;\n    this.objdumpExec = objdumpExec;\n    this.readelfExec = readelfExec;\n    this.targetRootFS = targetRootFS;\n    this.apkEmbeddedLibrary = apkEmbeddedLibrary;\n    this.FUNC_RE = /^([0-9a-fA-F]{8\x2C16}) ([0-9a-fA-F]{8\x2C16} )?[tTwW] (.*)$/;\n  }\n\n  _setRemoteQueryParams(searchParams) {\n    super._setRemoteQueryParams(searchParams);\n    searchParams.set('targetRootFS'\x2C this.targetRootFS ?? "");\n    searchParams.set('apkEmbeddedLibrary'\x2C this.apkEmbeddedLibrary);\n  }\n\n  _handleRemoteSymbolsResult(json) {\n    super._handleRemoteSymbolsResult(json);\n    this.fileOffsetMinusVma = json.fileOffsetMinusVma;\n  }\n\n  async loadSymbols(libName) {\n    this.parsePos = 0;\n    if (this.apkEmbeddedLibrary && libName.endsWith('.apk')) {\n      libName = this.apkEmbeddedLibrary;\n    }\n    if (this.targetRootFS) {\n      libName = libName.substring(libName.lastIndexOf('/') + 1);\n      libName = this.targetRootFS + libName;\n    }\n    try {\n      this.symbols = [\n        os.system(this.nmExec\x2C ['-C'\x2C '-n'\x2C '-S'\x2C libName]\x2C -1\x2C -1)\x2C\n        os.system(this.nmExec\x2C ['-C'\x2C '-n'\x2C '-S'\x2C '-D'\x2C libName]\x2C -1\x2C -1)\n      ];\n\n      try {\n        // Try to find separate debug symbols for the library in\n        // /usr/lib/debug/.build-id\x2C getting the build-id from the binary\n        // notes using readelf.\n        const binaryNotes = os.system(this.readelfExec\x2C ['-n'\x2C libName]\x2C -1\x2C -1)\n        const buildId = /Build ID: ([a-zA-Z0-9]+)/.exec(binaryNotes)?.[1]?.toLowerCase() ?? null;\n\n        if (buildId) {\n          const debugLibName = `/usr/lib/debug/.build-id/${buildId.slice(0\x2C 2)}/${buildId.slice(2)}.debug`;\n          this.symbols.push(\n            os.system(this.nmExec\x2C ['-C'\x2C '-n'\x2C '-S'\x2C debugLibName]\x2C -1\x2C -1)\x2C\n            os.system(this.nmExec\x2C ['-C'\x2C '-n'\x2C '-S'\x2C '-D'\x2C debugLibName]\x2C -1\x2C -1)\n          );\n        }\n      } catch {\n        // Ignore errors.\n      }\n\n      const objdumpOutput = os.system(this.objdumpExec\x2C ['-h'\x2C libName]\x2C -1\x2C -1);\n      for (const line of objdumpOutput.split('\\n')) {\n        const [\x2C sectionName\x2C \x2C vma\x2C \x2C fileOffset] = line.trim().split(/\\s+/);\n        if (sectionName === ".text") {\n          this.fileOffsetMinusVma =\n              this.parseHexAddr(fileOffset) - this.parseHexAddr(vma);\n        }\n      }\n    } catch (e) {\n      // If the library cannot be found on this system let's not panic.\n      this.symbols = [''\x2C ''];\n    }\n  }\n\n  parseNextLine() {\n    if (this.symbols.length == 0) return false;\n    const lineEndPos = this.symbols[0].indexOf('\\n'\x2C this.parsePos);\n    if (lineEndPos == -1) {\n      this.symbols.shift();\n      this.parsePos = 0;\n      return this.parseNextLine();\n    }\n\n    const line = this.symbols[0].substring(this.parsePos\x2C lineEndPos);\n    this.parsePos = lineEndPos + 1;\n    const fields = line.match(this.FUNC_RE);\n    if (fields === null) return null;\n\n    const funcInfo = {\n      name: fields[3]\x2C\n      start: this.parseHexAddr(fields[1]) + this.fileOffsetMinusVma\n    };\n    if (fields[2]) {\n      funcInfo.size = this.parseHexAddr(fields[2]);\n    }\n    return funcInfo;\n  }\n}\n\nexport class RemoteLinuxCppEntriesProvider extends LinuxCppEntriesProvider {\n  async loadSymbols(libName) {\n    return this.loadSymbolsRemote('linux'\x2C libName);\n  }\n}\n\nexport class MacOSCppEntriesProvider extends LinuxCppEntriesProvider {\n  constructor(\n        nmExec\x2C objdumpExec\x2C readelfExec\x2C targetRootFS\x2C apkEmbeddedLibrary\x2C\n        useBigIntAddresses=false) {\n    super(\n        nmExec\x2C objdumpExec\x2C readelfExec\x2C targetRootFS\x2C apkEmbeddedLibrary\x2C\n        useBigIntAddresses);\n    // Note an empty group. It is required\x2C as LinuxCppEntriesProvider expects 3 groups.\n    this.FUNC_RE = /^([0-9a-fA-F]{8\x2C16})() (.*)$/;\n  }\n\n  async loadSymbols(libName) {\n    this.parsePos = 0;\n    libName = this.targetRootFS + libName;\n\n    // It seems that in OS X `nm` thinks that `-f` is a format option\x2C not a\n    // "flat" display option flag.\n    try {\n      this.symbols = [\n        os.system(this.nmExec\x2C ['--demangle'\x2C '-n'\x2C libName]\x2C -1\x2C -1)\x2C ''\n      ];\n    } catch (e) {\n      // If the library cannot be found on this system let's not panic.\n      this.symbols = '';\n    }\n  }\n}\n\nexport class RemoteMacOSCppEntriesProvider extends LinuxCppEntriesProvider {\n  async loadSymbols(libName) {\n    return this.loadSymbolsRemote('macos'\x2C libName);\n  }\n}\n\n\nexport class WindowsCppEntriesProvider extends CppEntriesProvider {\n\n  static FILENAME_RE = /^(.*)\\.([^.]+)$/;\n  static FUNC_RE =\n    /^\\s+0001:[0-9a-fA-F]{8}\\s+([_\\?@$0-9a-zA-Z]+)\\s+([0-9a-fA-F]{8}).*$/;\n  static IMAGE_BASE_RE =\n    /^\\s+0000:00000000\\s+___ImageBase\\s+([0-9a-fA-F]{8}).*$/;\n\n  constructor(\n        _ignored_nmExec\x2C _ignored_objdumpExec\x2C _ignored_readelfExec\x2C\n        targetRootFS\x2C _ignored_apkEmbeddedLibrary\x2C useBigIntAddresses) {\n    super(useBigIntAddresses);\n    this.targetRootFS = targetRootFS;\n    this.symbols = '';\n    this.parsePos = 0;\n    // This is almost a constant on Windows.\n    this.EXE_IMAGE_BASE = this.parseAddr(0x00400000);\n  }\n\n  loadSymbols(libName) {\n    libName = this.targetRootFS + libName;\n    const fileNameFields = libName.match(WindowsCppEntriesProvider.FILENAME_RE);\n    if (fileNameFields === null) return;\n    const mapFileName = `${fileNameFields[1]}.map`;\n    this.moduleType_ = fileNameFields[2].toLowerCase();\n    try {\n      this.symbols = read(mapFileName);\n    } catch (e) {\n      // If .map file cannot be found let's not panic.\n      this.symbols = '';\n    }\n  }\n\n  parseNextLine() {\n    const lineEndPos = this.symbols.indexOf('\\r\\n'\x2C this.parsePos);\n    if (lineEndPos === -1) {\n      return false;\n    }\n\n    const line = this.symbols.substring(this.parsePos\x2C lineEndPos);\n    this.parsePos = lineEndPos + 2;\n\n    // Image base entry is above all other symbols\x2C so we can just\n    // terminate parsing.\n    const imageBaseFields = line.match(WindowsCppEntriesProvider.IMAGE_BASE_RE);\n    if (imageBaseFields !== null) {\n      const imageBase = this.parseHexAddr(imageBaseFields[1]);\n      if ((this.moduleType_ === 'exe') !=\n        (imageBase === this.EXE_IMAGE_BASE)) {\n        return false;\n      }\n    }\n\n    const fields = line.match(WindowsCppEntriesProvider.FUNC_RE);\n    if (fields === null) return null\n    return {\n      name: this.unmangleName(fields[1])\x2C\n      start: this.parseHexAddr(fields[2])\n    };\n  }\n\n  /**\n   * Performs very simple unmangling of C++ names.\n   *\n   * Does not handle arguments and template arguments. The mangled names have\n   * the form:\n   *\n   *   ?LookupInDescriptor@JSObject@internal@v8@@...arguments info...\n   */\n  unmangleName(name) {\n    // Empty or non-mangled name.\n    if (name.length < 1 || name.charAt(0) != '?') return name;\n    const nameEndPos = name.indexOf('@@');\n    const components = name.substring(1\x2C nameEndPos).split('@');\n    components.reverse();\n    return components.join('::');\n  }\n}\n\n\nexport class ArgumentsProcessor extends BaseArgumentsProcessor {\n  getArgsDispatch() {\n    let dispatch = {\n      __proto__:null\x2C\n      '-j': ['stateFilter'\x2C TickProcessor.VmStates.JS\x2C\n        'Show only ticks from JS VM state']\x2C\n      '-g': ['stateFilter'\x2C TickProcessor.VmStates.GC\x2C\n        'Show only ticks from GC VM state']\x2C\n      '-p': ['stateFilter'\x2C TickProcessor.VmStates.PARSER\x2C\n        'Show only ticks from PARSER VM state']\x2C\n      '-b': ['stateFilter'\x2C TickProcessor.VmStates.BYTECODE_COMPILER\x2C\n        'Show only ticks from BYTECODE_COMPILER VM state']\x2C\n      '-c': ['stateFilter'\x2C TickProcessor.VmStates.COMPILER\x2C\n        'Show only ticks from COMPILER VM state']\x2C\n      '-o': ['stateFilter'\x2C TickProcessor.VmStates.OTHER\x2C\n        'Show only ticks from OTHER VM state']\x2C\n      '-e': ['stateFilter'\x2C TickProcessor.VmStates.EXTERNAL\x2C\n        'Show only ticks from EXTERNAL VM state']\x2C\n      '--filter-runtime-timer': ['runtimeTimerFilter'\x2C null\x2C\n        'Show only ticks matching the given runtime timer scope']\x2C\n      '--call-graph-size': ['callGraphSize'\x2C TickProcessor.CALL_GRAPH_SIZE\x2C\n        'Set the call graph size']\x2C\n      '--ignore-unknown': ['ignoreUnknown'\x2C true\x2C\n        'Exclude ticks of unknown code entries from processing']\x2C\n      '--separate-ic': ['separateIc'\x2C parseBool\x2C\n        'Separate IC entries']\x2C\n      '--separate-bytecodes': ['separateBytecodes'\x2C parseBool\x2C\n        'Separate Bytecode entries']\x2C\n      '--separate-builtins': ['separateBuiltins'\x2C parseBool\x2C\n        'Separate Builtin entries']\x2C\n      '--separate-stubs': ['separateStubs'\x2C parseBool\x2C\n        'Separate Stub entries']\x2C\n      '--separate-sparkplug-handlers': ['separateSparkplugHandlers'\x2C parseBool\x2C\n        'Separate Sparkplug Handler entries']\x2C\n      '--linux': ['platform'\x2C 'linux'\x2C\n        'Specify that we are running on *nix platform']\x2C\n      '--windows': ['platform'\x2C 'windows'\x2C\n        'Specify that we are running on Windows platform']\x2C\n      '--mac': ['platform'\x2C 'macos'\x2C\n        'Specify that we are running on Mac OS X platform']\x2C\n      '--nm': ['nm'\x2C 'nm'\x2C\n        'Specify the \\'nm\\' executable to use (e.g. --nm=/my_dir/nm)']\x2C\n      '--objdump': ['objdump'\x2C 'objdump'\x2C\n        'Specify the \\'objdump\\' executable to use (e.g. --objdump=/my_dir/objdump)']\x2C\n      '--readelf': ['readelf'\x2C 'readelf'\x2C\n        'Specify the \\'readelf\\' executable to use (e.g. --readelf=/my_dir/readelf)']\x2C\n      '--target': ['targetRootFS'\x2C ''\x2C\n        'Specify the target root directory for cross environment']\x2C\n      '--apk-embedded-library': ['apkEmbeddedLibrary'\x2C ''\x2C\n        'Specify the path of the embedded library for Android traces']\x2C\n      '--range': ['range'\x2C 'auto\x2Cauto'\x2C\n        'Specify the range limit as [start]\x2C[end]']\x2C\n      '--distortion': ['distortion'\x2C 0\x2C\n        'Specify the logging overhead in picoseconds']\x2C\n      '--source-map': ['sourceMap'\x2C null\x2C\n        'Specify the source map that should be used for output']\x2C\n      '--timed-range': ['timedRange'\x2C true\x2C\n        'Ignore ticks before first and after last Date.now() call']\x2C\n      '--pairwise-timed-range': ['pairwiseTimedRange'\x2C true\x2C\n        'Ignore ticks outside pairs of Date.now() calls']\x2C\n      '--only-summary': ['onlySummary'\x2C true\x2C\n        'Print only tick summary\x2C exclude other information']\x2C\n      '--serialize-vm-symbols': ['serializeVMSymbols'\x2C true\x2C\n        'Print all C++ symbols and library addresses as JSON data']\x2C\n      '--preprocess': ['preprocessJson'\x2C true\x2C\n        'Preprocess for consumption with web interface']\x2C\n      '--use-bigint-addresses': ['useBigIntAddresses'\x2C true\x2C\n        'Use slower BigInts to precisely handle large addresses.']\n    };\n    dispatch['--js'] = dispatch['-j'];\n    dispatch['--gc'] = dispatch['-g'];\n    dispatch['--compiler'] = dispatch['-c'];\n    dispatch['--other'] = dispatch['-o'];\n    dispatch['--external'] = dispatch['-e'];\n    dispatch['--ptr'] = dispatch['--pairwise-timed-range'];\n    dispatch['--bigint-addresses'] = dispatch['--use-bigint-addresses'];\n    return dispatch;\n  }\n\n  getDefaultResults() {\n    return {\n      logFileName: 'v8.log'\x2C\n      platform: 'linux'\x2C\n      stateFilter: null\x2C\n      callGraphSize: 5\x2C\n      ignoreUnknown: false\x2C\n      separateIc: true\x2C\n      separateBytecodes: false\x2C\n      separateBuiltins: true\x2C\n      separateStubs: true\x2C\n      separateSparkplugHandlers: false\x2C\n      preprocessJson: null\x2C\n      sourceMap: null\x2C\n      targetRootFS: ''\x2C\n      nm: 'nm'\x2C\n      objdump: 'objdump'\x2C\n      readelf: 'readelf'\x2C\n      range: 'auto\x2Cauto'\x2C\n      distortion: 0\x2C\n      timedRange: false\x2C\n      pairwiseTimedRange: false\x2C\n      onlySummary: false\x2C\n      runtimeTimerFilter: null\x2C\n      serializeVMSymbols: false\x2C\n      useBigIntAddresses: false\x2C\n    };\n  }\n}\n\n\nexport class TickProcessor extends LogReader {\n  static EntriesProvider = {\n    'linux': LinuxCppEntriesProvider\x2C\n    'windows': WindowsCppEntriesProvider\x2C\n    'macos': MacOSCppEntriesProvider\n  };\n\n  static fromParams(params\x2C entriesProvider) {\n    if (entriesProvider == undefined) {\n      entriesProvider = new this.EntriesProvider[params.platform](\n          params.nm\x2C params.objdump\x2C params.readelf\x2C params.targetRootFS\x2C\n          params.apkEmbeddedLibrary);\n    }\n    return new TickProcessor(\n      entriesProvider\x2C\n      params.separateIc\x2C\n      params.separateBytecodes\x2C\n      params.separateBuiltins\x2C\n      params.separateStubs\x2C\n      params.separateSparkplugHandlers\x2C\n      params.callGraphSize\x2C\n      params.ignoreUnknown\x2C\n      params.stateFilter\x2C\n      params.distortion\x2C\n      params.range\x2C\n      params.sourceMap\x2C\n      params.timedRange\x2C\n      params.pairwiseTimedRange\x2C\n      params.onlySummary\x2C\n      params.runtimeTimerFilter\x2C\n      params.preprocessJson\x2C\n      params.useBigIntAddresses);\n  }\n\n  constructor(\n    cppEntriesProvider\x2C\n    separateIc\x2C\n    separateBytecodes\x2C\n    separateBuiltins\x2C\n    separateStubs\x2C\n    separateSparkplugHandlers\x2C\n    callGraphSize\x2C\n    ignoreUnknown\x2C\n    stateFilter\x2C\n    distortion\x2C\n    range\x2C\n    sourceMap\x2C\n    timedRange\x2C\n    pairwiseTimedRange\x2C\n    onlySummary\x2C\n    runtimeTimerFilter\x2C\n    preprocessJson\x2C\n    useBigIntAddresses) {\n    super(timedRange\x2C pairwiseTimedRange\x2C useBigIntAddresses);\n    this.useBigIntAddresses = useBigIntAddresses;\n    this.parseAddr = useBigIntAddresses ? BigInt : parseInt;\n    this.parseSize = this.parseAddr;\n    this.setDispatchTable({\n      __proto__: null\x2C\n      'shared-library': {\n        parsers: [parseString\x2C this.parseAddr\x2C this.parseAddr\x2C parseInt]\x2C\n        processor: this.processSharedLibrary\n      }\x2C\n      'code-creation': {\n        parsers: [parseString\x2C parseInt\x2C parseInt\x2C this.parseAddr\x2C\n            this.parseSize\x2C parseString\x2C parseVarArgs]\x2C\n        processor: this.processCodeCreation\n      }\x2C\n      'code-deopt': {\n        parsers: [parseInt\x2C this.parseSize\x2C this.parseAddr\x2C parseInt\x2C parseInt\x2C\n          parseString\x2C parseString\x2C parseString]\x2C\n        processor: this.processCodeDeopt\n      }\x2C\n      'code-move': {\n        parsers: [this.parseAddr\x2C this.parseAddr\x2C]\x2C\n        processor: this.processCodeMove\n      }\x2C\n      'code-source-info': {\n        parsers: [this.parseAddr\x2C parseInt\x2C parseInt\x2C parseInt\x2C parseString\x2C\n          parseString\x2C parseString]\x2C\n        processor: this.processCodeSourceInfo\n      }\x2C\n      'script-source': {\n        parsers: [parseInt\x2C parseString\x2C parseString]\x2C\n        processor: this.processScriptSource\n      }\x2C\n      'sfi-move': {\n        parsers: [this.parseAddr\x2C this.parseAddr]\x2C\n        processor: this.processSFIMove\n      }\x2C\n      'active-runtime-timer': {\n        parsers: [parseString]\x2C\n        processor: this.processRuntimeTimerEvent\n      }\x2C\n      'tick': {\n        parsers: [this.parseAddr\x2C parseInt\x2C parseInt\x2C\n          this.parseAddr\x2C parseInt\x2C parseVarArgs]\x2C\n        processor: this.processTick\n      }\x2C\n      'heap-sample-begin': {\n        parsers: [parseString\x2C parseString\x2C parseInt]\x2C\n        processor: this.processHeapSampleBegin\n      }\x2C\n      'heap-sample-end': {\n        parsers: [parseString\x2C parseString]\x2C\n        processor: this.processHeapSampleEnd\n      }\x2C\n      'timer-event-start': {\n        parsers: [parseString\x2C parseString\x2C parseString]\x2C\n        processor: this.advanceDistortion\n      }\x2C\n      'timer-event-end': {\n        parsers: [parseString\x2C parseString\x2C parseString]\x2C\n        processor: this.advanceDistortion\n      }\x2C\n      // Ignored events.\n      'profiler': undefined\x2C\n      'function-creation': undefined\x2C\n      'function-move': undefined\x2C\n      'function-delete': undefined\x2C\n      'heap-sample-item': undefined\x2C\n      'current-time': undefined\x2C  // Handled specially\x2C not parsed.\n      // Obsolete row types.\n      'code-allocate': undefined\x2C\n      'begin-code-region': undefined\x2C\n      'end-code-region': undefined\n    });\n\n    this.preprocessJson = preprocessJson;\n    this.cppEntriesProvider_ = cppEntriesProvider;\n    this.callGraphSize_ = callGraphSize;\n    this.ignoreUnknown_ = ignoreUnknown;\n    this.stateFilter_ = stateFilter;\n    this.runtimeTimerFilter_ = runtimeTimerFilter;\n    this.sourceMap = this.loadSourceMap(sourceMap);\n    const ticks = this.ticks_ =\n      { total: 0\x2C unaccounted: 0\x2C excluded: 0\x2C gc: 0 };\n\n    distortion = parseInt(distortion);\n    // Convert picoseconds to nanoseconds.\n    this.distortion_per_entry = isNaN(distortion) ? 0 : (distortion / 1000);\n    this.distortion = 0;\n    const rangelimits = range ? range.split("\x2C") : [];\n    const range_start = parseInt(rangelimits[0]);\n    const range_end = parseInt(rangelimits[1]);\n    // Convert milliseconds to nanoseconds.\n    this.range_start = isNaN(range_start) ? -Infinity : (range_start * 1000);\n    this.range_end = isNaN(range_end) ? Infinity : (range_end * 1000)\n\n    V8Profile.prototype.handleUnknownCode = function (\n      operation\x2C addr\x2C opt_stackPos) {\n      const op = Profile.Operation;\n      switch (operation) {\n        case op.MOVE:\n          printErr(`Code move event for unknown code: 0x${addr.toString(16)}`);\n          break;\n        case op.DELETE:\n          printErr(`Code delete event for unknown code: 0x${addr.toString(16)}`);\n          break;\n        case op.TICK:\n          // Only unknown PCs (the first frame) are reported as unaccounted\x2C\n          // otherwise tick balance will be corrupted (this behavior is compatible\n          // with the original tickprocessor.py script.)\n          if (opt_stackPos == 0) {\n            ticks.unaccounted++;\n          }\n          break;\n      }\n    };\n\n    if (preprocessJson) {\n      this.profile_ = new JsonProfile(useBigIntAddresses);\n    } else {\n      this.profile_ = new V8Profile(separateIc\x2C separateBytecodes\x2C\n          separateBuiltins\x2C separateStubs\x2C separateSparkplugHandlers\x2C\n          useBigIntAddresses);\n    }\n    this.codeTypes_ = {};\n    // Count each tick as a time unit.\n    this.viewBuilder_ = new ViewBuilder(1);\n    this.lastLogFileName_ = null;\n\n    this.generation_ = 1;\n    this.currentProducerProfile_ = null;\n    this.onlySummary_ = onlySummary;\n  }\n\n  loadSourceMap(sourceMap) {\n    if (!sourceMap) return null;\n    // Overwrite the load function to load scripts synchronously.\n    WebInspector.SourceMap.load = (sourceMapURL) => {\n      const content = d8.file.read(sourceMapURL);\n      const sourceMapObject = JSON.parse(content);\n      return new SourceMap(sourceMapURL\x2C sourceMapObject);\n    };\n    return WebInspector.SourceMap.load(sourceMap);\n  }\n\n  static VmStates = {\n    JS: 0\x2C\n    GC: 1\x2C\n    PARSER: 2\x2C\n    BYTECODE_COMPILER: 3\x2C\n    // TODO(cbruni): add SPARKPLUG_COMPILER\n    COMPILER: 4\x2C\n    OTHER: 5\x2C\n    EXTERNAL: 6\x2C\n    IDLE: 7\x2C\n  };\n\n  static CodeTypes = {\n    CPP: 0\x2C\n    SHARED_LIB: 1\n  };\n  // Otherwise\x2C this is JS-related code. We are not adding it to\n  // codeTypes_ map because there can be zillions of them.\n\n  static CALL_PROFILE_CUTOFF_PCT = 1.0;\n  static CALL_GRAPH_SIZE = 5;\n\n  /**\n   * @override\n   */\n  printError(str) {\n    printErr(str);\n  }\n\n  setCodeType(name\x2C type) {\n    this.codeTypes_[name] = TickProcessor.CodeTypes[type];\n  }\n\n  isSharedLibrary(name) {\n    return this.codeTypes_[name] == TickProcessor.CodeTypes.SHARED_LIB;\n  }\n\n  isCppCode(name) {\n    return this.codeTypes_[name] == TickProcessor.CodeTypes.CPP;\n  }\n\n  isJsCode(name) {\n    return name !== "UNKNOWN" && !(name in this.codeTypes_);\n  }\n\n  async processLogFile(fileName) {\n    this.lastLogFileName_ = fileName;\n    let line;\n    while (line = readline()) {\n      await this.processLogLine(line);\n    }\n  }\n\n  async processLogFileInTest(fileName) {\n    // Hack file name to avoid dealing with platform specifics.\n    this.lastLogFileName_ = 'v8.log';\n    const contents = d8.file.read(fileName);\n    await this.processLogChunk(contents);\n  }\n\n  processSharedLibrary(name\x2C startAddr\x2C endAddr\x2C aslrSlide) {\n    const entry = this.profile_.addLibrary(name\x2C startAddr\x2C endAddr);\n    this.setCodeType(entry.getName()\x2C 'SHARED_LIB');\n    this.cppEntriesProvider_.parseVmSymbols(\n      name\x2C startAddr\x2C endAddr\x2C aslrSlide\x2C (fName\x2C fStart\x2C fEnd) => {\n        this.profile_.addStaticCode(fName\x2C fStart\x2C fEnd);\n        this.setCodeType(fName\x2C 'CPP');\n      });\n  }\n\n  processCodeCreation(type\x2C kind\x2C timestamp\x2C start\x2C size\x2C name\x2C maybe_func) {\n    if (type != 'RegExp' && maybe_func.length) {\n      const sfiAddr = this.parseAddr(maybe_func[0]);\n      const state = Profile.parseState(maybe_func[1]);\n      this.profile_.addFuncCode(type\x2C name\x2C timestamp\x2C start\x2C size\x2C sfiAddr\x2C state);\n    } else {\n      this.profile_.addCode(type\x2C name\x2C timestamp\x2C start\x2C size);\n    }\n  }\n\n  processCodeDeopt(\n      timestamp\x2C size\x2C code\x2C inliningId\x2C scriptOffset\x2C bailoutType\x2C\n      sourcePositionText\x2C deoptReasonText) {\n    this.profile_.deoptCode(timestamp\x2C code\x2C inliningId\x2C scriptOffset\x2C\n      bailoutType\x2C sourcePositionText\x2C deoptReasonText);\n  }\n\n  processCodeMove(from\x2C to) {\n    this.profile_.moveCode(from\x2C to);\n  }\n\n  processCodeDelete(start) {\n    this.profile_.deleteCode(start);\n  }\n\n  processCodeSourceInfo(\n      start\x2C script\x2C startPos\x2C endPos\x2C sourcePositions\x2C inliningPositions\x2C\n      inlinedFunctions) {\n    this.profile_.addSourcePositions(start\x2C script\x2C startPos\x2C\n      endPos\x2C sourcePositions\x2C inliningPositions\x2C inlinedFunctions);\n  }\n\n  processScriptSource(script\x2C url\x2C source) {\n    this.profile_.addScriptSource(script\x2C url\x2C source);\n  }\n\n  processSFIMove(from\x2C to) {\n    this.profile_.moveSharedFunctionInfo(from\x2C to);\n  }\n\n  includeTick(vmState) {\n    if (this.stateFilter_ !== null) {\n      return this.stateFilter_ == vmState;\n    } else if (this.runtimeTimerFilter_ !== null) {\n      return this.currentRuntimeTimer == this.runtimeTimerFilter_;\n    }\n    return true;\n  }\n\n  processRuntimeTimerEvent(name) {\n    this.currentRuntimeTimer = name;\n  }\n\n  processTick(\n        pc\x2C ns_since_start\x2C is_external_callback\x2C tos_or_external_callback\x2C\n        vmState\x2C stack) {\n    this.distortion += this.distortion_per_entry;\n    ns_since_start -= this.distortion;\n    if (ns_since_start < this.range_start || ns_since_start > this.range_end) {\n      return;\n    }\n    this.ticks_.total++;\n    if (vmState == TickProcessor.VmStates.GC) this.ticks_.gc++;\n    if (!this.includeTick(vmState)) {\n      this.ticks_.excluded++;\n      return;\n    }\n    if (is_external_callback) {\n      // Don't use PC when in external callback code\x2C as it can point\n      // inside callback's code\x2C and we will erroneously report\n      // that a callback calls itself. Instead we use tos_or_external_callback\x2C\n      // as simply resetting PC will produce unaccounted ticks.\n      pc = tos_or_external_callback;\n      tos_or_external_callback = 0;\n    } else if (tos_or_external_callback) {\n      // Find out\x2C if top of stack was pointing inside a JS function\n      // meaning that we have encountered a frameless invocation.\n      const funcEntry = this.profile_.findEntry(tos_or_external_callback);\n      if (!funcEntry || !funcEntry.isJSFunction || !funcEntry.isJSFunction()) {\n        tos_or_external_callback = 0;\n      }\n    }\n\n    this.profile_.recordTick(\n      ns_since_start\x2C vmState\x2C\n      this.processStack(pc\x2C tos_or_external_callback\x2C stack));\n  }\n\n  advanceDistortion() {\n    this.distortion += this.distortion_per_entry;\n  }\n\n  processHeapSampleBegin(space\x2C state\x2C ticks) {\n    if (space != 'Heap') return;\n    this.currentProducerProfile_ = new CallTree();\n  }\n\n  processHeapSampleEnd(space\x2C state) {\n    if (space != 'Heap' || !this.currentProducerProfile_) return;\n\n    print(`Generation ${this.generation_}:`);\n    const tree = this.currentProducerProfile_;\n    tree.computeTotalWeights();\n    const producersView = this.viewBuilder_.buildView(tree);\n    // Sort by total time\x2C desc\x2C then by name\x2C desc.\n    producersView.sort((rec1\x2C rec2) =>\n      rec2.totalTime - rec1.totalTime ||\n      (rec2.internalFuncName < rec1.internalFuncName ? -1 : 1));\n    this.printHeavyProfile(producersView.head.children);\n\n    this.currentProducerProfile_ = null;\n    this.generation_++;\n  }\n\n  printVMSymbols() {\n    console.log(\n      JSON.stringify(this.profile_.serializeVMSymbols()));\n  }\n\n  printStatistics() {\n    if (this.preprocessJson) {\n      this.profile_.writeJson();\n      return;\n    }\n\n    print(`Statistical profiling result from ${this.lastLogFileName_}` +\n      `\x2C (${this.ticks_.total} ticks\x2C ${this.ticks_.unaccounted} unaccounted\x2C ` +\n      `${this.ticks_.excluded} excluded).`);\n\n\n    if (this.ticks_.total == 0) return;\n\n    const flatProfile = this.profile_.getFlatProfile();\n    const flatView = this.viewBuilder_.buildView(flatProfile);\n    // Sort by self time\x2C desc\x2C then by name\x2C desc.\n    flatView.sort((rec1\x2C rec2) =>\n      rec2.selfTime - rec1.selfTime ||\n      (rec2.internalFuncName < rec1.internalFuncName ? -1 : 1));\n    let totalTicks = this.ticks_.total;\n    if (this.ignoreUnknown_) {\n      totalTicks -= this.ticks_.unaccounted;\n    }\n    const printAllTicks = !this.onlySummary_;\n\n    // Count library ticks\n    const flatViewNodes = flatView.head.children;\n\n    let libraryTicks = 0;\n    if (printAllTicks) this.printHeader('Shared libraries');\n    this.printEntries(flatViewNodes\x2C totalTicks\x2C null\x2C\n      name => this.isSharedLibrary(name)\x2C\n      (rec) => { libraryTicks += rec.selfTime; }\x2C printAllTicks);\n    const nonLibraryTicks = totalTicks - libraryTicks;\n\n    let jsTicks = 0;\n    if (printAllTicks) this.printHeader('JavaScript');\n    this.printEntries(flatViewNodes\x2C totalTicks\x2C nonLibraryTicks\x2C\n      name => this.isJsCode(name)\x2C\n      (rec) => { jsTicks += rec.selfTime; }\x2C printAllTicks);\n\n    let cppTicks = 0;\n    if (printAllTicks) this.printHeader('C++');\n    this.printEntries(flatViewNodes\x2C totalTicks\x2C nonLibraryTicks\x2C\n      name => this.isCppCode(name)\x2C\n      (rec) => { cppTicks += rec.selfTime; }\x2C printAllTicks);\n\n    this.printHeader('Summary');\n    this.printLine('JavaScript'\x2C jsTicks\x2C totalTicks\x2C nonLibraryTicks);\n    this.printLine('C++'\x2C cppTicks\x2C totalTicks\x2C nonLibraryTicks);\n    this.printLine('GC'\x2C this.ticks_.gc\x2C totalTicks\x2C nonLibraryTicks);\n    this.printLine('Shared libraries'\x2C libraryTicks\x2C totalTicks\x2C null);\n    if (!this.ignoreUnknown_ && this.ticks_.unaccounted > 0) {\n      this.printLine('Unaccounted'\x2C this.ticks_.unaccounted\x2C\n        this.ticks_.total\x2C null);\n    }\n\n    if (printAllTicks) {\n      print('\\n [C++ entry points]:');\n      print('   ticks    cpp   total   name');\n      const c_entry_functions = this.profile_.getCEntryProfile();\n      const total_c_entry = c_entry_functions[0].ticks;\n      for (let i = 1; i < c_entry_functions.length; i++) {\n        const c = c_entry_functions[i];\n        this.printLine(c.name\x2C c.ticks\x2C total_c_entry\x2C totalTicks);\n      }\n\n      this.printHeavyProfHeader();\n      const heavyProfile = this.profile_.getBottomUpProfile();\n      const heavyView = this.viewBuilder_.buildView(heavyProfile);\n      // To show the same percentages as in the flat profile.\n      heavyView.head.totalTime = totalTicks;\n      // Sort by total time\x2C desc\x2C then by name\x2C desc.\n      heavyView.sort((rec1\x2C rec2) =>\n        rec2.totalTime - rec1.totalTime ||\n        (rec2.internalFuncName < rec1.internalFuncName ? -1 : 1));\n      this.printHeavyProfile(heavyView.head.children);\n    }\n  }\n\n  printHeader(headerTitle) {\n    print(`\\n [${headerTitle}]:`);\n    print('   ticks  total  nonlib   name');\n  }\n\n  printLine(\n    entry\x2C ticks\x2C totalTicks\x2C nonLibTicks) {\n    const pct = ticks * 100 / totalTicks;\n    const nonLibPct = nonLibTicks != null\n      ? `${(ticks * 100 / nonLibTicks).toFixed(1).toString().padStart(5)}%  `\n      : '        ';\n    print(`${`  ${ticks.toString().padStart(5)}  ` +\n      pct.toFixed(1).toString().padStart(5)}%  ${nonLibPct}${entry}`);\n  }\n\n  printHeavyProfHeader() {\n    print('\\n [Bottom up (heavy) profile]:');\n    print('  Note: percentage shows a share of a particular caller in the ' +\n      'total\\n' +\n      '  amount of its parent calls.');\n    print(`  Callers occupying less than ${TickProcessor.CALL_PROFILE_CUTOFF_PCT.toFixed(1)}% are not shown.\\n`);\n    print('   ticks parent  name');\n  }\n\n  processProfile(profile\x2C filterP\x2C func) {\n    for (let i = 0\x2C n = profile.length; i < n; ++i) {\n      const rec = profile[i];\n      if (!filterP(rec.internalFuncName)) {\n        continue;\n      }\n      func(rec);\n    }\n  }\n\n  getLineAndColumn(name) {\n    const re = /:([0-9]+):([0-9]+)$/;\n    const array = re.exec(name);\n    if (!array) {\n      return null;\n    }\n    return { line: array[1]\x2C column: array[2] };\n  }\n\n  hasSourceMap() {\n    return this.sourceMap != null;\n  }\n\n  formatFunctionName(funcName) {\n    if (!this.hasSourceMap()) {\n      return funcName;\n    }\n    const lc = this.getLineAndColumn(funcName);\n    if (lc == null) {\n      return funcName;\n    }\n    // in source maps lines and columns are zero based\n    const lineNumber = lc.line - 1;\n    const column = lc.column - 1;\n    const entry = this.sourceMap.findEntry(lineNumber\x2C column);\n    const sourceFile = entry[2];\n    const sourceLine = entry[3] + 1;\n    const sourceColumn = entry[4] + 1;\n\n    return `${sourceFile}:${sourceLine}:${sourceColumn} -> ${funcName}`;\n  }\n\n  printEntries(\n        profile\x2C totalTicks\x2C nonLibTicks\x2C filterP\x2C callback\x2C printAllTicks) {\n    this.processProfile(profile\x2C filterP\x2C (rec) => {\n      if (rec.selfTime == 0) return;\n      callback(rec);\n      const funcName = this.formatFunctionName(rec.internalFuncName);\n      if (printAllTicks) {\n        this.printLine(funcName\x2C rec.selfTime\x2C totalTicks\x2C nonLibTicks);\n      }\n    });\n  }\n\n  printHeavyProfile(profile\x2C opt_indent) {\n    const indent = opt_indent || 0;\n    const indentStr = ''.padStart(indent);\n    this.processProfile(profile\x2C () => true\x2C (rec) => {\n      // Cut off too infrequent callers.\n      if (rec.parentTotalPercent < TickProcessor.CALL_PROFILE_CUTOFF_PCT) return;\n      const funcName = this.formatFunctionName(rec.internalFuncName);\n      print(`${`  ${rec.totalTime.toString().padStart(5)}  ` +\n        rec.parentTotalPercent.toFixed(1).toString().padStart(5)}%  ${indentStr}${funcName}`);\n      // Limit backtrace depth.\n      if (indent < 2 * this.callGraphSize_) {\n        this.printHeavyProfile(rec.children\x2C indent + 2);\n      }\n      // Delimit top-level functions.\n      if (indent == 0) print('');\n    });\n  }\n}\n
